# Local .terraform internal binary directories
**/.terraform/*

# .tfstate mapping files (CRITICAL: Never commit state records to public tracking)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Ignore configuration variable sheets containing access parameters
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
